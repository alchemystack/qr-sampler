# Docker Compose configuration for qr-sampler
# Engine: {{ engine.name }}
# Model: {{ model }}
# Entropy source: {{ entropy_source.name }}
# Amplifier: {{ amplifier.name }}
# Sampler: {{ sampler.name }}
#
# Generated by: qr-sampler build

services:
{% if needs_entropy_server %}
  entropy-server:
    build:
      context: .
      dockerfile: examples/docker/Dockerfile.entropy-server
    ports:
      - "${ENTROPY_SERVER_PORT:-50051}:50051"
    environment:
      - ENTROPY_SERVER=${ENTROPY_SERVER:-simple_urandom_server.py}
    restart: unless-stopped

{% endif %}
{% if engine.docker.base_image %}
  inference:
    image: {{ engine.docker.base_image }}
    ports:
      - "${INFERENCE_PORT:-8000}:8000"
    environment:
      - MODEL={{ model }}
{% for key, value in engine_config.items() %}
      - {{ key | upper }}={{ value }}
{% endfor %}
{% if needs_entropy_server %}
      - QR_GRPC_SERVER_ADDRESS=entropy-server:50051
{% endif %}
{% for key, value in entropy_config.items() %}
      - QR_{{ key | upper }}={{ value }}
{% endfor %}
    volumes:
      - huggingface-cache:/root/.cache/huggingface
{% if engine.platform.accelerator and 'nvidia' in engine.platform.accelerator %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
{% endif %}
{% if needs_entropy_server %}
    depends_on:
      - entropy-server
{% endif %}
    restart: unless-stopped

{% endif %}
  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    ports:
      - "${WEBUI_PORT:-3000}:8080"
    environment:
      - OPENAI_API_BASE_URL=http://inference:8000/v1
      - OPENAI_API_KEY=${OPENAI_API_KEY:-dummy}
{% if engine.docker.base_image %}
    depends_on:
      - inference
{% endif %}
    volumes:
      - open-webui-data:/app/backend/data
    restart: unless-stopped

volumes:
  huggingface-cache:
  open-webui-data:
